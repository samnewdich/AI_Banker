# Example environment variables for local development
# Copy this file to .env and fill in the real values before running the app

MONGO_URI=mongodb+srv://admin:<db_password>@cluster0.u7vuvuk.mongodb.net/
JWT_SECRET=your_jwt_secret_here
TINYLLAMA_API_KEY=your_tinyllama_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here
NODE_ENV=development
PORT=3000

# Optional / example values
# REDIS_URL=redis://localhost:6379
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=supersecretpassword